# =============================================================================
# AI Translator — Environment Variable Template
# -----------------------------------------------------------------------------
# 1. Copy this file to a new file named ".env" in the same folder:
#       Windows (PowerShell):  copy .env.example .env
#       macOS / Linux:         cp .env.example .env
# 2. Fill in your real OpenAI API key below.
# 3. NEVER commit your real ".env" file to version control (it is already
#    excluded via .gitignore).
# =============================================================================

# --- REQUIRED ----------------------------------------------------------------

# Your secret OpenAI API key. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# --- OPTIONAL (sensible defaults are used if omitted) ------------------------

# Which OpenAI model to use with the Responses API.
OPENAI_MODEL=gpt-4o-mini

# Sampling temperature (0.0 = deterministic/precise, 2.0 = very creative).
# For translation accuracy, a low value like 0.2-0.4 is recommended.
DEFAULT_TEMPERATURE=0.3

# Timeout (in seconds) for each OpenAI API request.
OPENAI_REQUEST_TIMEOUT=30

# Flask server settings.
FLASK_DEBUG=True
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Used by Flask to sign session cookies. Change this to any random string.
FLASK_SECRET_KEY=change-this-to-a-random-secret-string

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
